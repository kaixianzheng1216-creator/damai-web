{
  "name": "damai-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "ci": "run-s type-check lint:check lint:oxlint audit:ids openapi:report test format:check build",
    "lint": "run-s lint:check",
    "lint:fix": "eslint . --fix --cache",
    "lint:check": "eslint . --cache=false",
    "lint:oxlint": "oxlint .",
    "audit:ids": "node scripts/audit-id-strategy.mjs",
    "openapi:report": "node scripts/openapi-contract-report.mjs",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check --experimental-cli src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,html,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-table": "^8.21.3",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-horizontal-rule": "^3.22.3",
    "@tiptap/extension-list": "^3.22.3",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extensions": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@unovis/vue": "^1.6.4",
    "@vueuse/core": "^14.2.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "lodash.throttle": "^4.1.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.29",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^5.0.3",
    "vue3-toastify": "^0.2.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.97",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.9",
    "@vue/tsconfig": "^0.8.1",
    "class-variance-authority": "^0.7.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.3",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "prettier": "3.8.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^6.0.11",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  }
}
