{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://192.168.10.1:18081",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/auth/verify-code": {
      "post": {
        "tags": [
          "认证接口"
        ],
        "summary": "发送验证码",
        "operationId": "sendVerifyCode",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendVerifyCodeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseVoid"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "认证接口"
        ],
        "summary": "用户登出",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseVoid"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "认证接口"
        ],
        "summary": "登录",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginWithCodeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseLoginResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendVerifyCodeRequest": {
        "type": "object",
        "description": "发送验证码请求",
        "properties": {
          "mobile": {
            "type": "string",
            "description": "手机号",
            "minLength": 1,
            "pattern": "^1[3-9]\\d{9}$"
          },
          "accountType": {
            "type": "string",
            "description": "账号类型: user-用户, admin-管理员",
            "minLength": 1,
            "pattern": "^(user|admin)$"
          }
        },
        "required": [
          "accountType",
          "mobile"
        ]
      },
      "ApiResponseVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        }
      },
      "LoginWithCodeRequest": {
        "type": "object",
        "description": "验证码登录请求",
        "properties": {
          "mobile": {
            "type": "string",
            "description": "手机号",
            "minLength": 1,
            "pattern": "^1[3-9]\\d{9}$"
          },
          "code": {
            "type": "string",
            "description": "验证码",
            "minLength": 1
          },
          "accountType": {
            "type": "string",
            "description": "账号类型: user 用户, admin 管理员",
            "minLength": 1,
            "pattern": "^(user|admin)$"
          }
        },
        "required": [
          "accountType",
          "code",
          "mobile"
        ]
      },
      "ApiResponseLoginResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/LoginResponse"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "description": "登录响应",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token"
          },
          "user": {
            "$ref": "#/components/schemas/UserVO",
            "description": "用户信息"
          }
        }
      },
      "UserVO": {
        "type": "object",
        "description": "用户信息 VO",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "用户 ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "mobile": {
            "type": "string",
            "description": "手机号"
          },
          "avatarUrl": {
            "type": "string",
            "description": "头像 URL"
          }
        }
      }
    }
  }
}