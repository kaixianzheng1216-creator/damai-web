{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://192.168.10.1:18087",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/front/ai/chat": {
      "get": {
        "tags": [
          "AI 前台接口"
        ],
        "summary": "AI 对话",
        "operationId": "chat",
        "parameters": [
          {
            "name": "flowName",
            "in": "query",
            "description": "Flow 名称: assistant-首页助手, support-客服工单",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "message",
            "in": "query",
            "description": "用户消息",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sessionId",
            "in": "query",
            "description": "会话 ID，同一会话需传入相同值",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAiChatResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AiChatItem": {
        "type": "object",
        "description": "AI 返回的活动条目",
        "properties": {
          "id": {
            "type": "string",
            "description": "活动 ID"
          },
          "name": {
            "type": "string",
            "description": "活动名称"
          },
          "coverUrl": {
            "type": "string",
            "description": "封面图 URL"
          },
          "venueName": {
            "type": "string",
            "description": "场馆名称"
          },
          "startTime": {
            "type": "string",
            "description": "开始时间"
          },
          "minPrice": {
            "type": "integer",
            "format": "int32",
            "description": "最低票价（分）"
          }
        }
      },
      "AiChatResponse": {
        "type": "object",
        "description": "AI 对话响应",
        "properties": {
          "message": {
            "type": "string",
            "description": "AI 回复消息"
          },
          "items": {
            "type": "array",
            "description": "相关活动",
            "items": {
              "$ref": "#/components/schemas/AiChatItem"
            }
          },
          "suggestions": {
            "type": "array",
            "description": "建议选项按钮",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ApiResponseAiChatResponse": {
        "type": "object",
        "description": "通用 API 响应结构",
        "properties": {
          "code": {
            "type": "string",
            "description": "响应码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/AiChatResponse",
            "description": "响应数据"
          }
        }
      }
    }
  }
}